# AWS Learning Platform - Environment Configuration
# Copy this file to .env and update values for production

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secure-key-in-production
DEBUG=False
PORT=5001
HOST=0.0.0.0

# Gamification Settings (Optional - defaults are good)
# POINTS_PER_LESSON=100
# POINTS_PER_QUIZ_QUESTION=10
# POINTS_PER_CHALLENGE=150
# POINTS_PER_LEVEL=500
# STREAK_BONUS_MULTIPLIER=0.1
# MAX_STREAK_BONUS=1.5

# Session Settings (Optional)
# SESSION_LIFETIME=86400

# Production Notes:
# 1. Generate a secure SECRET_KEY:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
#
# 2. Set DEBUG=False in production
#
# 3. Consider using a process manager like Gunicorn for production
#
# 4. Set up HTTPS/SSL with Let's Encrypt for secure connections
